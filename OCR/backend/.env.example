# OCR Backend Environment Variables
# Copy this file to .env and fill in real values.
# DO NOT commit .env to version control.

# ============================================================
# Database
# ============================================================
DATABASE_URL=mysql+pymysql://user:password@localhost:3306/wards_db

# ============================================================
# LLMWhisperer OCR
# ============================================================
LLMWHISPERER_API_KEY=
LLMWHISPERER_BASE_URL=https://llmwhisperer-api.us-central.unstract.com/api/v2

# ============================================================
# QuickEmailVerification (optional)
# ============================================================
QUICKEMAILVERIFICATION_API_KEY=

# ============================================================
# Brevo SMTP
# ============================================================
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USERNAME=
BREVO_SMTP_PASSWORD=
BREVO_SENDER_EMAIL=noreply@wards.gov
BREVO_SENDER_NAME=WARDS Taxpayer Verification

# ============================================================
# OTP Settings
# ============================================================
OTP_EXPIRE_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_HASH_SECRET=replace-with-a-long-random-otp-hash-secret

# ============================================================
# Deterministic Hashing for Sensitive Stored Business Fields
# ============================================================
DATA_HASH_SECRET=replace-with-a-long-random-data-hash-secret

# ============================================================
# App-side Encryption for Sensitive Readable Business Fields
# ============================================================
DATA_ENCRYPTION_SECRET=replace-with-a-long-random-data-encryption-secret

# ============================================================
# Phase 2 Plaintext Cutover
# ============================================================
WARDS_SECURITY_PHASE2_REDACT=true

# ============================================================
# Admin Credentials for OCR Staff/Admin Auth
# ============================================================
OCR_ADMIN_USERNAME=admin
OCR_ADMIN_PASSWORD=

# ============================================================
# JWT Secret for Taxpayer Authentication
# ============================================================
OCR_JWT_SECRET_KEY=replace-with-a-long-random-jwt-secret
