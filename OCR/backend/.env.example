DATABASE_URL=mysql+pymysql://root:password@localhost:3306/wards_queue_system

# QuickEmailVerification
QUICKEMAILVERIFICATION_API_KEY=your_quickemailverification_api_key

# Brevo SMTP
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USERNAME=your_brevo_smtp_login
BREVO_SMTP_PASSWORD=your_brevo_smtp_key
BREVO_SENDER_EMAIL=your_verified_sender@example.com
BREVO_SENDER_NAME=WARDS Taxpayer Verification

# OTP settings
OTP_EXPIRE_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_HASH_SECRET=change_this_random_secret

# Deterministic hashing for sensitive stored business fields
DATA_HASH_SECRET=change_this_data_hash_secret

# App-side encryption for sensitive readable business fields
DATA_ENCRYPTION_SECRET=change_this_data_encryption_secret

# Phase 2 plaintext cutover: replace legacy plaintext columns with redacted placeholders
WARDS_SECURITY_PHASE2_REDACT=true
