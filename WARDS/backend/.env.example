# WARDS Backend Environment Variables
# Copy this file to .env and fill in real values.
# DO NOT commit .env to version control.

# ============================================================
# JWT / Security Keys
# ============================================================
ADMIN_SECRET_KEY=replace-with-a-different-long-random-admin-secret
USER_SECRET_KEY=replace-with-a-long-random-user-secret
BRANCH_SECRET_KEY=replace-with-a-long-random-branch-secret
PASSWORD_RESET_SECRET_KEY=replace-with-a-long-random-password-reset-secret
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key
PAYMONGO_WEBHOOK_SECRET=your-paymongo-webhook-secret
DATA_ENCRYPTION_SECRET=replace-with-a-long-random-data-encryption-secret
DATA_HASH_SECRET=replace-with-a-long-random-data-hash-secret
LOG_INTEGRITY_SECRET=replace-with-a-long-random-log-integrity-secret
BACKUP_INTEGRITY_SECRET=replace-with-a-long-random-backup-integrity-secret

# ============================================================
# CORS / API
# ============================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
API_PORT=8000

# ============================================================
# Bootstrap Admins (created on first run if not present)
# ============================================================
ADMIN_EMAIL=
ADMIN_PASSWORD=
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=

# ============================================================
# Rate Limiting / Lockout
# ============================================================
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60

# ============================================================
# SMTP / Email
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@wards.gov
SMTP_FROM_NAME=WARDS Admin
SMTP_USE_TLS=true

# ============================================================
# Base URLs
# ============================================================
FRONTEND_BASE_URL=http://localhost:3000
BACKEND_BASE_URL=http://localhost:8000

# ============================================================
# QuickEmailVerification (optional)
# ============================================================
QUICKEMAILVERIFICATION_API_KEY=
QUICKEMAILVERIFICATION_TIMEOUT_SECONDS=8

# ============================================================
# PayMongo Payments (optional)
# ============================================================
PAYMONGO_SECRET_KEY=
PAYMONGO_PUBLIC_KEY=

# ============================================================
# LLMWhisperer OCR (optional)
# ============================================================
LLMWHISPERER_API_KEY=
LLMWHISPERER_BASE_URL=https://llmwhisperer-api.us-central.unstract.com/api/v2

# ============================================================
# Database
# ============================================================
DATABASE_URL=mysql+pymysql://user:password@localhost/wards_db

# ============================================================
# Security Monitoring
# ============================================================
SECURITY_DEPLOYMENT_MODE=development
SECURITY_MONITORING_ENABLED=false
WAZUH_ENABLED=false
SECURITY_SCAN_INTERVAL_SECONDS=30

# ============================================================
# Seed script passwords (optional — strong random passwords will be generated if left blank)
# ============================================================
SEED_ADMIN_PASSWORD=
SEED_BRANCH_STAFF_PASSWORD=
SEED_BRANCH_ADMIN_PASSWORD=
SEED_MAIN_ADMIN_PASSWORD=
SEED_GALAS_ADMIN_PASSWORD=
SEED_DISTRICT_ADMIN_PASSWORD=
SEED_GALAS_STAFF_PASSWORD=
SEED_DISTRICT_STAFF_PASSWORD=

# ============================================================
# Test script password
# ============================================================
TEST_ADMIN_PASSWORD=

# ============================================================
# DoS Protection Settings
# ============================================================
MAX_REQUEST_SIZE_BYTES=10485760
REQUEST_TIMEOUT_SECONDS=30
MAX_CONCURRENT_REQUESTS_PER_IP=50
ABUSE_THRESHOLD_REQUESTS=300
ABUSE_WINDOW_SECONDS=60
ADMIN_ABUSE_THRESHOLD_REQUESTS=600
SEARCH_ABUSE_THRESHOLD_REQUESTS=120
SEARCH_ABUSE_WINDOW_SECONDS=60
AUTH_ABUSE_THRESHOLD_REQUESTS=10
AUTH_ABUSE_WINDOW_SECONDS=900
REGISTRATION_ABUSE_THRESHOLD_REQUESTS=5
REGISTRATION_ABUSE_WINDOW_SECONDS=3600
PASSWORD_RESET_ABUSE_THRESHOLD_REQUESTS=5
PASSWORD_RESET_ABUSE_WINDOW_SECONDS=3600
ABUSE_STRIKE_WINDOW_SECONDS=604800
ABUSE_CAPTCHA_AFTER_STRIKES=2
REPUTATION_BLOCK_THRESHOLD=50
ABUSE_EXEMPT_PRIVATE_IPS=true
ABUSE_EXEMPT_IPS=127.0.0.1,::1,localhost

# ============================================================
# IP Reputation (AbuseIPDB)
# ============================================================
ABUSEIPDB_API_KEY=
ENABLE_IP_REPUTATION=false
AUTO_BLOCK_MALICIOUS=false
