# WARDS Backend Environment Variables
# Copy this file to .env and fill in real values.

# Database
DATABASE_URL=mysql+pymysql://user:password@localhost/wards_db

# JWT / Security
SECRET_KEY=your-super-secret-random-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Superadmin (bootstrap on first run)
SUPERADMIN_EMAIL=treasurersuper@gmail.com
SUPERADMIN_PASSWORD=

# Main admin (bootstrap on first run)
ADMIN_EMAIL=treasurermain@gmail.com
ADMIN_PASSWORD=

# Seed script passwords (optional — strong random passwords will be generated if left blank)
SEED_ADMIN_PASSWORD=
SEED_BRANCH_STAFF_PASSWORD=
SEED_BRANCH_ADMIN_PASSWORD=
SEED_MAIN_ADMIN_PASSWORD=
SEED_GALAS_ADMIN_PASSWORD=
SEED_DISTRICT_ADMIN_PASSWORD=
SEED_GALAS_STAFF_PASSWORD=
SEED_DISTRICT_STAFF_PASSWORD=

# Test script password
TEST_ADMIN_PASSWORD=

# SMTP / Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@wards.gov

# Backend base URL
BACKEND_BASE_URL=http://localhost:8000
